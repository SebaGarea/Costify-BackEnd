# Variables de entorno para el entorno DEMO
# Copiá este archivo como .env y reemplazá con los valores reales del cluster demo
# NUNCA uses las variables de producción aquí.

PORT=8080
NODE_ENV=production

# MongoDB Atlas — cluster FREE dedicado al demo (no el productivo)
MONGO_URL=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=costify_demo

# JWT — generá un string aleatorio seguro (podés usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=cambia-este-valor-por-uno-aleatorio-seguro

# Google OAuth — podés reusar las credenciales de producción o crear un proyecto nuevo en Google Cloud
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_CALLBACK_URL=https://<tu-servicio-demo>.onrender.com/api/usuarios/auth/google/callback

# CORS — URL del frontend demo en Vercel
CORS_ORIGINS=https://<tu-proyecto-demo>.vercel.app

# Cloudinary — opcional: podés reusar el mismo account de producción
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
