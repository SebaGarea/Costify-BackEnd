# ============================================================
#  Costify Backend — Variables de PRODUCCIÓN (Oracle Cloud)
# ============================================================
#  1. Copiá este archivo:   cp env.production.example .env.production
#  2. Completá los valores reales (los mismos que tenés en Render).
#  3. NUNCA subas .env.production al repo (está cubierto por .gitignore).
# ============================================================

# --- Dominio / HTTPS (los usa Caddy) -------------------------
DOMAIN=costify.duckdns.org
ACME_EMAIL=sebastiangarea@gmail.com

# --- Servidor ------------------------------------------------
PORT=8080
NODE_ENV=production

# --- Base de datos (Mongo Atlas — el MISMO que ya usás) ------
MONGO_URL=mongodb+srv://USUARIO:PASSWORD@cluster.xxxx.mongodb.net
DB_NAME=costify

# --- Auth ----------------------------------------------------
JWT_SECRET=pega-aca-el-MISMO-secret-que-tenés-en-render

# --- Google OAuth --------------------------------------------
# OJO: el callback ahora apunta al dominio nuevo. Hay que darlo de alta en
# Google Cloud Console -> APIs & Services -> Credentials -> tu OAuth Client
# -> Authorized redirect URIs (agregá la URL de abajo, sin borrar la de Render).
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_CALLBACK_URL=https://costify.duckdns.org/api/usuarios/auth/google/callback

# --- A dónde redirige el backend tras el login (tu frontend) -
FRONTEND_URL=https://tu-frontend.vercel.app
# Opcional: orígenes extra permitidos para la redirección (coma-separados)
FRONTEND_URLS=https://tu-frontend.vercel.app

# --- CORS: dominios del frontend autorizados (coma-separados) -
CORS_ORIGINS=https://tu-frontend.vercel.app

# --- Cloudinary (el MISMO que ya usás) -----------------------
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# --- IA (Gemini) — opcional ----------------------------------
GEMINI_API_KEY=tu-gemini-key
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Email (nodemailer) — opcional ---------------------------
EMAIL_HOST=smtp.tu-proveedor.com
EMAIL_PORT=587
EMAIL_USER=tu-usuario
EMAIL_PASS=tu-password
EMAIL_FROM=Costify <no-reply@tu-dominio.com>

# --- DNS (opcional) — solo si Atlas no resuelve en la VM -----
# DNS_SERVERS=1.1.1.1,8.8.8.8
